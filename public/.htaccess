Options -MultiViews
RewriteEngine On

# Redirect non-www to www (301 permanent)
RewriteCond %{HTTP_HOST} ^moudevpro\.com [NC]
RewriteRule ^(.*)$ https://www.moudevpro.com/$1 [R=301,L]

# SPA fallback
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [QSA,L]
