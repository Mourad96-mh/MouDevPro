{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "moudevpro.com" }],
      "destination": "https://www.moudevpro.com/$1",
      "permanent": true
    },
    {
      "source": "/agence-web-marrakech",
      "destination": "/marrakech",
      "permanent": true
    },
    {
      "source": "/agence-web-marrakech/",
      "destination": "/marrakech",
      "permanent": true
    },
    {
      "source": "/agence-web-rabat",
      "destination": "/rabat",
      "permanent": true
    },
    {
      "source": "/agence-web-rabat/",
      "destination": "/rabat",
      "permanent": true
    },
    {
      "source": "/agence-web-tanger",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/agence-web-tanger/",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
